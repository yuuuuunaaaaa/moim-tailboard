<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Admin - moim-tailboard</title>
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        max-width: 960px;
        margin: 24px auto;
        padding: 0 16px;
      }
      h1 {
        margin-bottom: 16px;
      }
      .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
      }
      @media (max-width: 768px) {
        .grid {
          grid-template-columns: 1fr;
        }
      }
      .panel {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 16px;
      }
      .panel h2 {
        margin-top: 0;
      }
      label {
        display: block;
        margin-bottom: 4px;
        font-weight: 500;
      }
      input[type="text"],
      input[type="date"],
      input[type="datetime-local"],
      select,
      textarea {
        width: 100%;
        padding: 6px 8px;
        border-radius: 4px;
        border: 1px solid #ccc;
        margin-bottom: 8px;
      }
      textarea {
        min-height: 120px;
      }
      .btn {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 4px;
        border: 1px solid #ccc;
        background: #1d4ed8;
        color: white;
        cursor: pointer;
        font-size: 0.875rem;
      }
      .tenant-list {
        margin-bottom: 8px;
      }
      .tenant-list a {
        margin-right: 8px;
      }
    </style>
  </head>
  <body>
    <h1>Admin</h1>

    <div class="tenant-list">
      <strong>Tenants:</strong>
      <% tenants.forEach(function(t){ %>
      <a href="/t/<%= t.slug %>/events"><%= t.name %></a>
      <% }) %>
    </div>

    <div class="grid">
      <div class="panel">
        <h2>Create Event</h2>
        <form method="post" action="/admin/events">
          <label for="tenantSlug">Tenant</label>
          <select id="tenantSlug" name="tenantSlug" required>
            <option value="">Select tenant</option>
            <% tenants.forEach(function(t){ %>
            <option value="<%= t.slug %>"><%= t.name %> (<%= t.slug %>)</option>
            <% }) %>
          </select>

          <label for="title">Title</label>
          <input id="title" name="title" required />

          <label for="description">Description</label>
          <textarea id="description" name="description"></textarea>

          <label for="eventDate">Event Date/Time</label>
          <input id="eventDate" name="eventDate" type="datetime-local" required />

          <label>
            <input type="checkbox" name="isActive" value="true" checked />
            Active
          </label>

          <label for="adminTelegram">Admin Telegram ID</label>
          <input id="adminTelegram" name="telegramId" />

          <button class="btn" type="submit">Create Event</button>
        </form>
      </div>

      <div class="panel">
        <h2>Create Option Group</h2>
        <form method="post" action="/admin/options">
          <label for="tenantSlug2">Tenant</label>
          <select id="tenantSlug2" name="tenantSlug" required>
            <option value="">Select tenant</option>
            <% tenants.forEach(function(t){ %>
            <option value="<%= t.slug %>"><%= t.name %> (<%= t.slug %>)</option>
            <% }) %>
          </select>

          <label for="eventId">Event ID</label>
          <input id="eventId" name="eventId" required />

          <label for="groupName">Group Name</label>
          <input id="groupName" name="groupName" required />

          <label>
            <input type="checkbox" name="multipleSelect" value="true" />
            Allow multiple selection
          </label>

          <label for="options">Options (one per line)</label>
          <textarea id="options" name="options"></textarea>

          <label for="adminTelegram2">Admin Telegram ID</label>
          <input id="adminTelegram2" name="telegramId" />

          <button class="btn" type="submit">Create Option Group</button>
        </form>
      </div>
    </div>
  </body>
  </html>

