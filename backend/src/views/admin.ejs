<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>관리 · 모임 테일보드</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet" />
  <style>
    .event-admin-list { list-style: none; padding: 0; margin: 0 0 20px 0; }
    .event-admin-item {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 4px; border-bottom: 1px solid var(--border);
    }
    .event-admin-item:last-child { border-bottom: none; }
    .event-admin-info { flex: 1; }
    .event-admin-title { font-weight: 500; font-size: 0.9375rem; }
    .event-admin-date { font-size: 0.8125rem; color: var(--muted); margin-top: 2px; }
    .badge { font-size: 0.72rem; padding: 2px 8px; border-radius: 999px; font-weight: 500; }
    .badge--on { background: var(--primary-light); color: var(--primary-hover); }
    .badge--off { background: #f3f4f6; color: var(--muted); }
    .event-edit-form { display: none; padding: 10px 0 4px; }
    .event-edit-form .row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 8px; }
    .event-edit-form .row input, .event-edit-form .row textarea { flex: 1; min-width: 120px; }
    .icon-btn {
      background: none; border: none; cursor: pointer;
      color: var(--muted); padding: 4px; border-radius: 4px; line-height: 0;
    }
    .icon-btn:hover { color: var(--primary); background: var(--bg); }
  </style>
</head>
<body>
  <header class="page-header">
    <div class="container">
      <div class="brand">
        <a href="/">모임 테일보드</a><% if (username) { %> <span class="brand-username">(<%= username %>)</span><% } %>
      </div>
      <nav class="nav-links">
        <% if (canChooseTenant) { %><a href="/">공동체 선택</a><% } %>
        <a href="/admin">관리</a>
      </nav>
    </div>
  </header>
  <main class="container container--wide">
    <h1>관리 — <%= tenant.name %></h1>

    <div class="tenant-pills">
      <% if (tenants.length > 1) { %>
        <select onchange="location.href='/admin?tenant='+this.value">
          <% tenants.forEach(function(t){ %>
            <option value="<%= t.slug %>" <%= t.id === tenant.id ? 'selected' : '' %>><%= t.name %></option>
          <% }); %>
        </select>
      <% } %>
      <a href="/t/<%= tenant.slug %>/events">이벤트 목록</a>
      <a href="/admin/tenants/<%= tenant.slug %>">관리자 설정</a>
    </div>

    <div class="admin-grid">

      <!-- 이벤트 목록 + 수정 -->
      <div class="card" style="grid-column: 1 / -1;">
        <h2 class="card__title">이벤트 목록</h2>
        <% if (events.length === 0) { %>
          <p class="empty-state mt-0 mb-0">아직 이벤트가 없습니다. 아래에서 만들어 주세요.</p>
        <% } else { %>
        <ul class="event-admin-list">
          <% events.forEach(function(ev){ %>
          <li>
            <div class="event-admin-item">
              <div class="event-admin-info">
                <div class="event-admin-title"><%= ev.title %></div>
                <div class="event-admin-date"><%= new Date(ev.event_date).toISOString().slice(0,16).replace('T',' ') %></div>
              </div>
              <span class="badge <%= ev.is_active ? 'badge--on' : 'badge--off' %>">
                <%= ev.is_active ? '공개' : '비공개' %>
              </span>
              <form method="post" action="/admin/events/<%= ev.id %>/toggle" style="display:inline">
                <input type="hidden" name="tenantSlug" value="<%= tenant.slug %>" />
                <button class="icon-btn" title="<%= ev.is_active ? '비공개로 전환' : '공개로 전환' %>">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </form>
              <button class="icon-btn" onclick="toggleEventEdit(<%= ev.id %>)" title="수정">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <a href="/t/<%= tenant.slug %>/events/<%= ev.id %>" class="icon-btn" title="보기">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
              <form method="post" action="/admin/events/<%= ev.id %>/delete" style="display:inline"
                    onsubmit="return confirm('이벤트와 모든 참여자 데이터가 삭제됩니다. 계속하시겠습니까?')">
                <input type="hidden" name="tenantSlug" value="<%= tenant.slug %>" />
                <button class="icon-btn" style="color:var(--danger)" title="삭제">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                </button>
              </form>
            </div>
            <!-- 수정 폼 -->
            <form class="event-edit-form" id="edit-<%= ev.id %>" method="post" action="/admin/events/<%= ev.id %>/update">
              <input type="hidden" name="tenantSlug" value="<%= tenant.slug %>" />
              <div class="row">
                <input type="text" name="title" value="<%= ev.title %>" placeholder="제목" required />
                <input type="datetime-local" name="eventDate" value="<%= new Date(ev.event_date).toISOString().slice(0,16) %>" required />
              </div>
              <div class="row">
                <textarea name="description" placeholder="설명(선택)"></textarea>
              </div>
              <!-- 기존 옵션 그룹 목록 + 삭제 -->
              <% var groups = groupsByEvent[ev.id] || []; %>
              <% if (groups.length > 0) { %>
              <div style="margin-bottom:10px;">
                <div style="font-size:0.8125rem;font-weight:600;margin-bottom:6px;color:var(--muted);">현재 옵션 그룹</div>
                <% groups.forEach(function(g){ %>
                <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;font-size:0.875rem;">
                  <span style="flex:1;"><b><%= g.name %></b> · <%= g.items.map(function(i){return i.name;}).join(", ") %></span>
                  <form method="post" action="/admin/option-groups/<%= g.id %>/delete" style="display:inline"
                        onsubmit="return confirm('옵션 그룹을 삭제하시겠습니까?')">
                    <input type="hidden" name="tenantSlug" value="<%= tenant.slug %>" />
                    <button class="icon-btn" style="color:var(--danger);font-size:0.75rem;" title="그룹 삭제">✕</button>
                  </form>
                </div>
                <% }) %>
              </div>
              <% } %>
              <!-- 새 옵션 그룹 추가 -->
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                <span style="font-size:0.8125rem;font-weight:600;color:var(--muted);">옵션 그룹 추가</span>
                <button type="button" class="btn btn--secondary btn--sm" onclick="addEditGroup(<%= ev.id %>)">+ 추가</button>
              </div>
              <div id="edit-og-<%= ev.id %>"></div>
              <div style="display:flex;gap:6px;margin-top:8px;">
                <button class="btn btn--primary btn--sm" type="submit">저장</button>
                <button class="btn btn--sm" type="button" onclick="toggleEventEdit(<%= ev.id %>)">닫기</button>
              </div>
            </form>
          </li>
          <% }) %>
        </ul>
        <% } %>
      </div>

      <!-- 이벤트 만들기 -->
      <div class="card" style="grid-column: 1 / -1;">
        <h2 class="card__title">이벤트 만들기</h2>
        <form method="post" action="/admin/events" id="event-create-form">
          <input type="hidden" name="tenantSlug" value="<%= tenant.slug %>" />
          <input type="hidden" name="username" value="<%= username || '' %>" />
          <div class="admin-grid" style="margin-bottom:0;">
            <div>
              <div class="form-group">
                <label>제목</label>
                <input name="title" required placeholder="예: 3/7 인천 수련회" />
              </div>
              <div class="form-group">
                <label>설명 <span class="optional">(선택)</span></label>
                <textarea name="description" placeholder="이벤트 설명"></textarea>
              </div>
              <div class="form-group">
                <label>일시</label>
                <input name="eventDate" type="datetime-local" required />
              </div>
              <div class="form-group">
                <label>
                  <input type="checkbox" name="isActive" value="true" checked />
                  공개 (목록에 표시)
                </label>
              </div>
            </div>
            <div>
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                <span style="font-weight:600;font-size:0.9375rem;">옵션 그룹 <span class="optional">(선택)</span></span>
                <button type="button" class="btn btn--secondary btn--sm" onclick="addOptionGroup()">+ 그룹 추가</button>
              </div>
              <div id="option-groups"></div>
            </div>
          </div>
          <div style="margin-top:16px;">
            <button class="btn btn--primary" type="submit">이벤트 만들기</button>
          </div>
        </form>
      </div>

      <!-- 옵션 그룹 추가 -->
      <div class="card">
        <h2 class="card__title">옵션 그룹 추가</h2>
        <form method="post" action="/admin/options">
          <input type="hidden" name="tenantSlug" value="<%= tenant.slug %>" />
          <input type="hidden" name="username" value="<%= username || '' %>" />
          <div class="form-group">
            <label for="eventId">이벤트</label>
            <select id="eventId" name="eventId" required>
              <option value="">이벤트 선택</option>
              <% events.forEach(function(ev){ %>
              <option value="<%= ev.id %>"><%= ev.title %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label for="groupName">그룹 이름</label>
            <input id="groupName" name="groupName" required placeholder="예: 식사, 이동, 파트" />
          </div>
          <div class="form-group">
            <label>
              <input type="checkbox" name="multipleSelect" value="true" />
              여러 개 선택 가능
            </label>
          </div>
          <div class="form-group">
            <label for="options">옵션 (한 줄에 하나)</label>
            <textarea id="options" name="options" placeholder="식사 O&#10;식사 X"></textarea>
          </div>
          <button class="btn btn--primary" type="submit">옵션 그룹 추가</button>
        </form>
      </div>
    </div>
  </main>
  <script>
    function toggleEventEdit(id) {
      var f = document.getElementById("edit-" + id);
      f.style.display = f.style.display === "block" ? "none" : "block";
    }

    var _editIdx = {};
    function addEditGroup(evId) {
      if (!_editIdx[evId]) _editIdx[evId] = 0;
      var idx = _editIdx[evId]++;
      var wrap = document.getElementById("edit-og-" + evId);
      var div = document.createElement("div");
      div.className = "option-group-card";
      div.id = "eog-" + evId + "-" + idx;
      div.innerHTML =
        '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">' +
          '<input type="text" class="og-name" placeholder="그룹 이름" style="flex:1" />' +
          '<label style="white-space:nowrap;font-size:0.8125rem;margin:0;">' +
            '<input type="checkbox" class="og-multi" style="width:auto;margin-right:4px;" /> 복수선택' +
          '</label>' +
          '<button type="button" class="icon-btn" onclick="document.getElementById(\'eog-' + evId + '-' + idx + '\').remove()" title="삭제">✕</button>' +
        '</div>' +
        '<textarea class="og-text" placeholder="항목 (한 줄에 하나)" style="height:70px;width:100%;"></textarea>';
      wrap.appendChild(div);
    }

    // 수정 폼 submit 시 옵션 그룹 직렬화
    document.querySelectorAll(".event-edit-form").forEach(function (form) {
      form.addEventListener("submit", function () {
        var evId = form.id.replace("edit-", "");
        var wrap = document.getElementById("edit-og-" + evId);
        if (!wrap) return;
        wrap.querySelectorAll(".option-group-card").forEach(function (card) {
          var name = card.querySelector(".og-name").value.trim();
          var multi = card.querySelector(".og-multi").checked ? "true" : "false";
          var text = card.querySelector(".og-text").value;
          if (!name) return;
          [["groupName", name], ["multipleSelect", multi], ["optionText", text]].forEach(function (pair) {
            var inp = document.createElement("input");
            inp.type = "hidden"; inp.name = pair[0]; inp.value = pair[1];
            form.appendChild(inp);
          });
        });
      });
    });

    var _groupIdx = 0;
    function addOptionGroup() {
      var idx = _groupIdx++;
      var wrap = document.getElementById("option-groups");
      var div = document.createElement("div");
      div.className = "option-group-card";
      div.id = "og-" + idx;
      div.innerHTML =
        '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">' +
          '<input type="text" class="og-name" placeholder="그룹 이름 (예: 식사)" style="flex:1" />' +
          '<label style="white-space:nowrap;font-size:0.8125rem;margin:0;">' +
            '<input type="checkbox" class="og-multi" style="width:auto;margin-right:4px;" /> 복수선택' +
          '</label>' +
          '<button type="button" class="icon-btn" onclick="removeGroup(' + idx + ')" title="삭제">✕</button>' +
        '</div>' +
        '<textarea class="og-text" placeholder="항목 (한 줄에 하나)&#10;예: 식사 O&#10;식사 X" style="height:80px;width:100%;"></textarea>';
      wrap.appendChild(div);
    }

    function removeGroup(idx) {
      var el = document.getElementById("og-" + idx);
      if (el) el.remove();
    }

    // submit 전 option-groups를 hidden input으로 직렬화
    document.getElementById("event-create-form").addEventListener("submit", function () {
      var cards = document.querySelectorAll("#option-groups .option-group-card");
      cards.forEach(function (card) {
        var name = card.querySelector(".og-name").value.trim();
        var multi = card.querySelector(".og-multi").checked ? "true" : "false";
        var text = card.querySelector(".og-text").value;
        if (!name) return;
        addHidden("groupName", name);
        addHidden("multipleSelect", multi);
        addHidden("optionText", text);
      });
      function addHidden(n, v) {
        var inp = document.createElement("input");
        inp.type = "hidden"; inp.name = n; inp.value = v;
        document.getElementById("event-create-form").appendChild(inp);
      }
    });
  </script>
</body>
</html>
