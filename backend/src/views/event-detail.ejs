<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#0d9488" />
  <title><%= event.title %> · <%= tenant.name %></title>
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
  <link rel="stylesheet" href="/style.css" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet" />
</head>
<body>
  <header class="page-header">
    <div class="container">
      <div class="brand">
        <% if (canChooseTenant) { %><a href="/">꼬리달기</a><% } else { %><a href="/t/<%= tenant.slug %>/events">꼬리달기</a><% } %>
        <% if (username) { %> <span class="brand-username">(<%= username %>)</span><% } %>
      </div>
      <nav class="nav-links">
        <a href="/t/<%= tenant.slug %>/events">이벤트 목록</a>
        <% if (canChooseTenant) { %><a href="/">지역 선택</a><% } %>
        <% if (isAdmin) { %><a href="/admin">관리</a><% } %>
      </nav>
    </div>
  </header>
  <main class="container container--wide">
    <a href="/t/<%= tenant.slug %>/events" class="back-link">← <%= tenant.name %> 이벤트 목록</a>
    <h1><%= event.title %></h1>
    <p class="page-subtitle">
      <%= event.eventDate.toISOString().slice(0,16).replace('T',' ') %> ·
      <% if (event.description) { %><%= event.description %><% } else { %>이벤트에 참여해 주세요.<% } %>
    </p>

    <div class="layout-half">
      <div class="card">
        <h2 class="card__title">참여 신청</h2>
        <form method="post" action="/participants">
          <input type="hidden" name="tenantSlug" value="<%= tenant.slug %>" />
          <input type="hidden" name="eventId" value="<%= event.id %>" />

          <div class="form-group">
            <label for="name">이름</label>
            <input id="name" name="name" required placeholder="이름을 입력하세요" value="" />
          </div>
          <div class="form-group">
            <label for="studentNo">학번 <span class="optional">(동명이인일 때만)</span></label>
            <input id="studentNo" name="studentNo" placeholder="선택 입력" />
          </div>
          <div class="form-group">
            <label for="username">사용자명</label>
            <% if (username) { %>
            <input id="username" type="text" readonly class="input-readonly" value="<%= username %>" />
            <p class="form-hint">로그인한 계정으로 참여됩니다.</p>
            <% } else { %>
            <p class="form-hint form-hint--warning">로그인이 필요합니다. <a href="/login">로그인</a>하거나 텔레그램에서 열어 주세요.</p>
            <% } %>
          </div>

          <% event.optionGroups.forEach(function(group){ %>
          <div class="form-group option-group">
            <div class="option-group__name"><%= group.name %></div>
            <% if (group.multipleSelect) { %>
            <div class="checkbox-group">
              <% group.options.forEach(function(opt){ %>
              <label>
                <input type="checkbox" name="optionItemIds" value="<%= opt.id %>" />
                <%= opt.name %><% if (opt.limitEnabled && opt.limitCount) { %> (정원 <%= opt.limitCount %>명)<% } %>
              </label>
              <% }) %>
            </div>
            <% } else { %>
            <div class="radio-group">
              <% group.options.forEach(function(opt){ %>
              <label>
                <input type="radio" name="optionItemIds" value="<%= opt.id %>" />
                <%= opt.name %><% if (opt.limitEnabled && opt.limitCount) { %> (정원 <%= opt.limitCount %>명)<% } %>
              </label>
              <% }) %>
            </div>
            <% } %>
          </div>
          <% }) %>

          <button class="btn btn--primary" type="submit" <%= !username ? 'disabled title="텔레그램에서 열어 로그인해 주세요"' : '' %>>참여하기</button>
        </form>
      </div>

      <div class="card">
        <h2 class="card__title">참여자 (<%= event.participants.length %>명)</h2>
        <% if (event.participants.length === 0) { %>
        <p class="empty-state mt-0 mb-0">아직 참여자가 없습니다.</p>
        <% } else { %>
        <ul class="p-list">
          <% event.participants.forEach(function(p, idx){ %>
          <li class="p-item" id="p-item-<%= p.id %>">
            <!-- 보기 모드 -->
            <div class="p-view">
              <span class="p-num"><%= idx + 1 %></span>
              <span class="p-info">
                <span class="p-name"><%= p.name %><% if (p.studentNo) { %> <span class="p-sno">(<%= p.studentNo %>)</span><% } %></span>
                <% if (event.optionGroups.length > 0) { %>
                <span class="p-opts">
                  <% event.optionGroups.forEach(function(group){ %>
                  <% var sels = p.options.filter(function(po){ return po.optionItem.optionGroupId === group.id; }).map(function(po){ return po.optionItem.name; }); %>
                  <% if (sels.length > 0) { %><span class="p-opt-tag"><%= sels.join(", ") %></span><% } %>
                  <% }) %>
                </span>
                <% } %>
              </span>
              <% if (username && p.username === username) { %>
              <button class="p-edit-btn" type="button" onclick="toggleEdit(<%= p.id %>)" title="수정">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <% } %>
            </div>
            <!-- 수정 모드 (숨김) -->
            <% if (username && p.username === username) { %>
            <form class="p-edit-form" id="p-edit-<%= p.id %>" method="post" action="/participants/update" style="display:none">
              <input type="hidden" name="tenantSlug" value="<%= tenant.slug %>" />
              <input type="hidden" name="participantId" value="<%= p.id %>" />
              <div class="p-edit-fields">
                <input type="text" name="name" value="<%= p.name %>" placeholder="이름" />
                <input type="text" name="studentNo" value="<%= p.studentNo || '' %>" placeholder="학번(선택)" />
              </div>
              <div class="p-edit-actions">
                <button class="btn btn--secondary btn--sm" type="submit" name="mode" value="update">저장</button>
                <button class="btn btn--sm" type="button" onclick="toggleEdit(<%= p.id %>)">닫기</button>
                <button class="btn btn--danger btn--sm" type="submit" name="mode" value="delete"
                  onclick="return confirm('참여를 취소하시겠습니까?')">삭제</button>
              </div>
            </form>
            <% } %>
          </li>
          <% }) %>
        </ul>
        <% } %>
      </div>
    </div>
  </main>
  <script>
    function toggleEdit(id) {
      var view = document.querySelector("#p-item-" + id + " .p-view");
      var form = document.getElementById("p-edit-" + id);
      if (!form) return;
      var editing = form.style.display !== "none";
      form.style.display = editing ? "none" : "block";
      view.style.opacity = editing ? "1" : "0.5";
    }
  </script>
  <script>
    (function () {
      var alreadyAuthed = !!("<%= username %>");
      if (alreadyAuthed) return;
      var tg = window.Telegram && window.Telegram.WebApp;
      if (!tg || !tg.initData) {
        // WebApp 컨텍스트 아님 → 로그인 페이지로
        location.href = "/login";
        return;
      }
      tg.ready();
      tg.expand();
      fetch("/auth/telegram-webapp", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ initData: tg.initData }),
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.ok || !data.token) {
            location.href = "/login";
            return;
          }
          var maxAge = 90 * 24 * 60 * 60;
          document.cookie = "auth_token=" + data.token + "; path=/; max-age=" + maxAge;
          var uname = data.user && (data.user.username || String(data.user.id));
          if (uname) document.cookie = "username=" + uname + "; path=/; max-age=" + maxAge;
          location.reload();
        })
        .catch(function () { location.href = "/login"; });
    })();
  </script>
</body>
</html>
