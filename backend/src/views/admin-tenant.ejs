<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= tenant.name %> 관리자 · 모임 테일보드</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet" />
  <style>
    .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 0.9375rem; }
    .alert--error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; }
    .alert--success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; }
    .admin-list-table .actions { white-space: nowrap; }
  </style>
</head>
<body>
  <header class="page-header">
    <div class="container">
      <div class="brand"><a href="/">모임 테일보드</a></div>
      <nav class="nav-links">
        <a href="/admin">관리</a>
        <a href="/t/<%= tenant.slug %>/events">이벤트</a>
        <a href="/">공동체 선택</a>
      </nav>
    </div>
  </header>
  <main class="container container--wide">
    <a href="/admin" class="back-link">← 관리</a>
    <h1><%= tenant.name %> · 관리자</h1>
    <p class="page-subtitle">이 공동체의 관리자를 추가·삭제할 수 있습니다. 사용자명으로 식별됩니다.</p>

    <% if (error === 'username_required') { %>
    <p class="alert alert--error" role="alert">사용자명을 입력해 주세요.</p>
    <% } %>
    <% if (error === 'username_duplicate') { %>
    <p class="alert alert--error" role="alert">이 사용자명은 이미 다른 공동체의 관리자로 등록되어 있습니다. 한 사람은 한 공동체의 관리자만 될 수 있습니다.</p>
    <% } %>
    <% if (error === 'not_found') { %>
    <p class="alert alert--error" role="alert">해당 관리자를 찾을 수 없습니다.</p>
    <% } %>
    <% if (success === 'added') { %>
    <p class="alert alert--success" role="alert">관리자를 추가했습니다.</p>
    <% } %>
    <% if (success === 'removed') { %>
    <p class="alert alert--success" role="alert">관리자를 삭제했습니다.</p>
    <% } %>

    <div class="admin-grid">
      <div class="card">
        <h2 class="card__title">관리자 추가</h2>
        <form method="post" action="/admin/tenants/<%= tenant.slug %>/admins">
          <div class="form-group">
            <label for="username">사용자명 <span class="optional">(필수)</span></label>
            <input id="username" name="username" required placeholder="예: yuna9354 (@ 없이)" />
          </div>
          <div class="form-group">
            <label for="adminName">표시 이름 <span class="optional">(선택)</span></label>
            <input id="adminName" name="name" placeholder="예: 홍길동" />
          </div>
          <button class="btn btn--primary" type="submit">관리자 추가</button>
        </form>
      </div>

      <div class="card">
        <h2 class="card__title">현재 관리자 (<%= admins.length %>명)</h2>
        <% if (admins.length === 0) { %>
        <p class="empty-state mt-0 mb-0">등록된 관리자가 없습니다. 위 폼에서 추가해 주세요.</p>
        <% } else { %>
        <div class="participants-wrap">
          <table class="table admin-list-table">
            <thead>
              <tr>
                <th>사용자명</th>
                <th>이름</th>
                <th>추가일</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% admins.forEach(function(a){ %>
              <tr>
                <td><code><%= a.username %></code></td>
                <td><%= a.name || '—' %></td>
                <td><%= new Date(a.created_at).toLocaleDateString('ko-KR') %></td>
                <td class="actions">
                  <form method="post" action="/admin/tenants/<%= tenant.slug %>/admins/<%= a.id %>/delete" style="display:inline;" onsubmit="return confirm('이 관리자를 삭제할까요?');">
                    <button type="submit" class="btn btn--danger">삭제</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
