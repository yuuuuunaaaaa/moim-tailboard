<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= tenant.name %> · 이벤트</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet" />
</head>
<body>
  <header class="page-header">
    <div class="container">
      <div class="brand">
        <% if (canChooseTenant) { %><a href="/">꼬리달기</a><% } else { %><a href="/t/<%= tenant.slug %>/events">꼬리달기</a><% } %>
        <% if (username) { %> <span class="brand-username">(<%= username %>)</span><% } %>
      </div>
      <nav class="nav-links">
        <% if (canChooseTenant) { %><a href="/">지역 선택</a><% } %>
        <% if (isAdmin) { %><a href="/admin">관리</a><% } %>
      </nav>
    </div>
  </header>
  <main class="container">
    <% if (canChooseTenant) { %><a href="/" class="back-link">← 지역 선택</a><% } %>
    <h1><%= tenant.name %></h1>
    <p class="page-subtitle">진행 중인 이벤트에 참여할 수 있습니다.</p>
    <% if (events.length === 0) { %>
    <div class="empty-state">
      진행 중인 이벤트가 없습니다.
      <% if (isAdmin) { %>
      <div style="margin-top: 16px;">
        <a href="/admin?tenant=<%= tenant.slug %>" class="btn btn--primary">이벤트 만들기</a>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <ul class="event-list">
      <% events.forEach(function(event){ %>
      <li class="event-item">
        <a href="/t/<%= tenant.slug %>/events/<%= event.id %>"><%= event.title %></a>
        <div class="event-meta">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          <%= event.eventDate.toISOString().slice(0,10) %>
        </div>
      </li>
      <% }) %>
    </ul>
    <% } %>
  </main>

  <% if (isAdmin) { %>
  <a href="/admin?tenant=<%= tenant.slug %>" class="admin-fab" title="관리 페이지">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M12 14c-5 0-8 2-8 3v1h16v-1c0-1-3-3-8-3z"/><path d="M19 3l2 2-9 9-4 1 1-4z"/></svg>
  </a>
  <% } %>
</body>
</html>
