<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>꼬리달기</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet" />
</head>
<body>
  <header class="page-header">
    <div class="container">
      <div class="brand">
        <a href="/">꼬리달기</a><% if (username) { %> <span class="brand-username">(<%= username %>)</span><% } %>
      </div>
      <nav class="nav-links">
        <% if (canChooseTenant) { %><a href="/">지역 선택</a><% } %>
        <% if (isAdmin) { %><a href="/admin">관리</a><% } %>
      </nav>
    </div>
  </header>
  <main class="container">
    <h1>지역 선택</h1>
    <% if (canChooseTenant) { %>
    <p class="page-subtitle">참여할 지역을 선택하세요.</p>
    <% if (tenants.length === 0) { %>
    <div class="empty-state">등록된 지역이 없습니다.</div>
    <% } else { %>
    <ul class="event-list">
      <% tenants.forEach(function(t){ %>
      <li class="event-item">
        <a href="/t/<%= t.slug %>/events"><%= t.name %></a>
        <div class="event-meta"><%= t.slug %></div>
      </li>
      <% }) %>
    </ul>
    <% } %>
    <p style="margin-top: 24px;">
      <a href="/admin" class="btn btn--secondary">관리자 페이지</a>
    </p>
    <% } else if (isAdmin) { %>
    <p class="page-subtitle">지역 선택은 최고 관리자만 가능합니다.</p>
    <p style="margin-top: 24px;">
      <a href="/admin" class="btn btn--secondary">관리자 페이지</a>
    </p>
    <% } else { %>
    <p class="page-subtitle">지역 선택과 관리는 로그인된 관리자만 가능합니다.</p>
    <p class="form-hint">참여할 이벤트 링크로 접속해 주세요.</p>
    <p style="margin-top: 24px;">
      <a href="/login" class="btn btn--secondary">관리자 로그인</a>
    </p>
    <% } %>
  </main>
</body>
</html>
