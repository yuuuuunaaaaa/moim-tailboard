NODE_ENV=development
PORT=3000

# DB (server only)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL_CA_CONTENT=
# DB_SSL_CA=/path/to/ca.pem

# Auth (server only) — JWT 만료는 코드에서 7d 고정 (jose)
# 관리자 행(admin 테이블) 조회 캐시 TTL(초). 0이면 매 요청 DB 조회. 기본 300.
# ADMIN_CACHE_REVALIDATE_SECONDS=300
JWT_SECRET=
TELEGRAM_BOT_TOKEN=
# 봇 @TailboardBot → 사용자명만 (without @)
NEXT_PUBLIC_TELEGRAM_BOT_NAME=TailboardBot
# 브라우저→텔레그램 앱 점프용 (t.me 만 가능). 자체 도메인(vercel.app 등) 넣지 말 것 — 그건 BotFather Mini App URL.
# NEXT_PUBLIC_TELEGRAM_WEBAPP_OPEN_URL=https://t.me/TailboardBot/moim
# 또는 짧은 이름만 넣으면 https://t.me/{BOT_NAME}/{SHORT} 로 조합
# NEXT_PUBLIC_TELEGRAM_MINI_APP_SHORT_NAME=moim
# 개발 시 자동 t.me 이동 끄기: 1
# NEXT_PUBLIC_TELEGRAM_LOGIN_SKIP_WEBAPP_REDIRECT=1
# 브라우저 Login 위젯 비상용 표시: 1
# NEXT_PUBLIC_TELEGRAM_LOGIN_WIDGET_FALLBACK=1
# 선택: 위젯 사용 시 봇 DM 권한 요청
# NEXT_PUBLIC_TELEGRAM_WIDGET_REQUEST_ACCESS=write

# Public (client + server)
NEXT_PUBLIC_APP_URL=https://moim-tailboard.vercel.app
