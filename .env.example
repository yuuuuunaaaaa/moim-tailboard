NODE_ENV=development
PORT=3000

# DB (server only)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL_CA_CONTENT=
# DB_SSL_CA=/path/to/ca.pem

# Auth (server only) — JWT 만료는 코드에서 7d 고정 (jose)
# 관리자 행(admin 테이블) 조회 캐시 TTL(초). 0이면 매 요청 DB 조회. 기본 300.
# ADMIN_CACHE_REVALIDATE_SECONDS=300
JWT_SECRET=
TELEGRAM_BOT_TOKEN=
# Login 위젯용 = BotFather에 보이는 Username (@ 제외). 예: @TailboardBot → TailboardBot
NEXT_PUBLIC_TELEGRAM_BOT_NAME=TailboardBot
# 선택: 로그인 시 봇이 사용자에게 DM 보낼 권한까지 요청하려면 write (기본 미설정 권장)
# NEXT_PUBLIC_TELEGRAM_WIDGET_REQUEST_ACCESS=write

# Public (client + server)
NEXT_PUBLIC_APP_URL=https://moim-tailboard.vercel.app
